import { useState, useRef, useEffect } from "react";

const AGENTS = [
  { id: "oracle", name: "Oracle", role: "Persönlicher Assistent", emoji: "🔮", color: "#3B82F6",
    sys: "Du bist ein kluger persönlicher Assistent. Hilf bei Alltag, Entscheidungen, Planung, Shopping. Direkt und ehrlich. Auf Deutsch." },
  { id: "builder", name: "Builder", role: "Business & Marketing", emoji: "🏗", color: "#F97316",
    sys: "Du denkst wie Jeff Bezos und Alex Hormozi. Hilf bei Business, Marketing, Kundengewinnung, Skalierung. Zahlen und konkrete Schritte. Auf Deutsch." },
  { id: "innovator", name: "Innovator", role: "Ideen & Innovation", emoji: "⚡", color: "#EF4444",
    sys: "Du denkst wie Elon Musk und Steve Jobs. First Principles. 10x-Denken. Neue Geschäftsideen, Nischen, kreative Lösungen. Auf Deutsch." },
  { id: "investor", name: "Investor", role: "Finanzen & Vermögen", emoji: "💎", color: "#10B981",
    sys: "Du denkst wie Warren Buffett. Finanzplanung, Investieren, Vermögensaufbau, passives Einkommen. Allgemeine Finanzbildung. Auf Deutsch." },
  { id: "market", name: "Markt", role: "Trading & Börse", emoji: "📊", color: "#34D399",
    sys: "Du bist Marktanalytiker wie Ray Dalio. Erkläre Märkte, Aktien, Wirtschaftsereignisse. Allgemeine Bildung, keine Beratung. Auf Deutsch." },
  { id: "performer", name: "Performer", role: "Fitness & Mindset", emoji: "🔥", color: "#F43F5E",
    sys: "Du denkst wie David Goggins und Andrew Huberman. Keine Ausreden. Trainingspläne, Ernährung, Energie, Mindset. Auf Deutsch." },
  { id: "philosopher", name: "Strategie", role: "Ziele & Lebensdesign", emoji: "∞", color: "#8B5CF6",
    sys: "Du denkst wie Naval Ravikant und Marcus Aurelius. Ziele, Gewohnheiten, Produktivitat, Lebensplanung. Kurz und tief. Auf Deutsch." },
  { id: "techmind", name: "TechMind", role: "KI & Automation", emoji: "◈", color: "#06B6D4",
    sys: "Du bist KI-Experte. Erkläre KI-Tools, Automationen mit Make.com, n8n, Zapier, WhatsApp Business API. Praxisnah. Auf Deutsch." },
  { id: "advisor", name: "Advisor", role: "Shopping & Käufe", emoji: "◐", color: "#F59E0B",
    sys: "Du bist unparteiischer Kaufberater. Empfehlungen für Autos, Elektronik, Geschenke. Pros und Cons. Konkrete Empfehlung am Ende. Auf Deutsch." },
];

async function chat(sys, messages) {
  try {
    const r = await fetch("/api/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ system: sys, messages }),
    });
    const d = await r.json();
    return d.text || d.error || "Keine Antwort.";
  } catch (e) {
    return "Verbindungsfehler – bitte nochmal senden.";
  }
}

export default function SecondBrain() {
  const [agent, setAgent] = useState(AGENTS[0]);
  const [convos, setConvos] = useState({});
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const [sidebar, setSidebar] = useState(true);
  const endRef = useRef(null);
  const taRef = useRef(null);

  const msgs = convos[agent.id] || [];

  useEffect(() => { endRef.current?.scrollIntoView({ behavior: "smooth" }); }, [msgs, loading]);

  const send = async (text) => {
    const q = (text || input).trim();
    if (!q || loading) return;
    const userMsg = { role: "user", content: q };
    const newMsgs = [...msgs, userMsg];
    setConvos((p) => ({ ...p, [agent.id]: newMsgs }));
    setInput("");
    if (taRef.current) taRef.current.style.height = "auto";
    setLoading(true);
    const reply = await chat(agent.sys, newMsgs);
    setConvos((p) => ({ ...p, [agent.id]: [...newMsgs, { role: "assistant", content: reply }] }));
    setLoading(false);
  };

  const onKey = (e) => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); send(); } };

  return (
    <div style={{ display: "flex", height: "100vh", background: "#06070A", color: "#F5F7FC", fontFamily: "-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif", overflow: "hidden" }}>
      <style>{`
        * { box-sizing: border-box; -webkit-font-smoothing: antialiased; }
        ::-webkit-scrollbar { width: 3px; } ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 3px; }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
        @keyframes pulse { 0%,100% { opacity: .4; } 50% { opacity: 1; } }
        @keyframes dot { 0%,80%,100% { transform: scale(.5); opacity: .3; } 40% { transform: scale(1); opacity: 1; } }
        .msg { animation: fadeUp .2s ease; }
        .agbtn:hover { background: rgba(255,255,255,.05) !important; }
        .chip:hover { opacity: .8; transform: translateY(-1px); }
        .sendbtn:hover:not(:disabled) { filter: brightness(1.2); transform: scale(1.08); }
        button, input, textarea { font-family: inherit; }
        textarea::placeholder, input::placeholder { color: rgba(245,247,252,.28); }
      `}</style>

      {/* Sidebar */}
      <div style={{ width: sidebar ? 220 : 56, minWidth: sidebar ? 220 : 56, background: "rgba(18,20,28,.9)", backdropFilter: "blur(24px)", borderRight: "1px solid rgba(255,255,255,.08)", display: "flex", flexDirection: "column", transition: "width .2s ease, min-width .2s ease", overflow: "hidden", flexShrink: 0 }}>
        <div style={{ padding: "14px 11px 12px", borderBottom: "1px solid rgba(255,255,255,.08)", display: "flex", alignItems: "center", gap: 9 }}>
          <div style={{ width: 34, height: 34, minWidth: 34, background: "linear-gradient(135deg,#7C3AED,#3B82F6,#06B6D4)", borderRadius: 10, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 16, flexShrink: 0 }}>🧠</div>
          {sidebar && <div><div style={{ fontSize: 11, fontWeight: 700, letterSpacing: ".08em" }}>SECOND BRAIN</div><div style={{ fontSize: 8.5, color: "rgba(245,247,252,.28)", marginTop: 1 }}>{AGENTS.length} AGENTEN</div></div>}
        </div>

        <div style={{ flex: 1, padding: "6px 5px", overflowY: "auto" }}>
          {sidebar && <div style={{ fontSize: 8, fontWeight: 700, color: "rgba(245,247,252,.28)", letterSpacing: ".14em", padding: "7px 6px 5px" }}>AGENTEN</div>}
          {AGENTS.map((ag) => {
            const active = agent.id === ag.id;
            const n = (convos[ag.id] || []).filter((m) => m.role === "user").length;
            return (
              <button key={ag.id} className="agbtn" onClick={() => setAgent(ag)} style={{ width: "100%", padding: sidebar ? "7px 8px" : "7px 0", marginBottom: 1, background: active ? `${ag.color}14` : "transparent", border: `1px solid ${active ? ag.color + "30" : "transparent"}`, borderRadius: 9, cursor: "pointer", display: "flex", alignItems: "center", gap: 8, justifyContent: sidebar ? "flex-start" : "center", textAlign: "left", transition: "all .12s" }}>
                <div style={{ width: 28, height: 28, minWidth: 28, borderRadius: 8, background: active ? `${ag.color}22` : "rgba(255,255,255,.07)", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 14, flexShrink: 0 }}>{ag.emoji}</div>
                {sidebar && <><div style={{ flex: 1, minWidth: 0 }}><div style={{ fontSize: 11.5, fontWeight: 500, color: active ? ag.color : "rgba(245,247,252,.55)", whiteSpace: "nowrap", overflow: "hidden", textOverflow: "ellipsis" }}>{ag.name}</div><div style={{ fontSize: 9, color: "rgba(245,247,252,.28)" }}>{ag.role}</div></div>{n > 0 && <div style={{ padding: "1px 5px", background: `${ag.color}20`, color: ag.color, borderRadius: 8, fontSize: 8.5, fontWeight: 700 }}>{n}</div>}</>}
              </button>
            );
          })}
        </div>

        <div style={{ padding: "5px", borderTop: "1px solid rgba(255,255,255,.08)" }}>
          <button onClick={() => setSidebar((s) => !s)} style={{ width: "100%", padding: "6px", background: "transparent", border: "1px solid rgba(255,255,255,.05)", borderRadius: 8, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: sidebar ? "flex-start" : "center", gap: 6, color: "rgba(245,247,252,.28)", fontSize: 10 }}>
            <span>{sidebar ? "◀" : "▶"}</span>{sidebar && "Einklappen"}
          </button>
        </div>
      </div>

      {/* Main */}
      <div style={{ flex: 1, display: "flex", flexDirection: "column", overflow: "hidden" }}>
        {/* Header */}
        <div style={{ padding: "11px 16px", borderBottom: "1px solid rgba(255,255,255,.08)", background: "rgba(18,20,28,.9)", backdropFilter: "blur(24px)", display: "flex", alignItems: "center", justifyContent: "space-between", flexShrink: 0 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
            <div style={{ width: 36, height: 36, borderRadius: 10, background: `${agent.color}18`, border: `1.5px solid ${agent.color}35`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 17 }}>{agent.emoji}</div>
            <div>
              <div style={{ fontSize: 14, fontWeight: 600 }}>{agent.name}</div>
              <div style={{ display: "flex", alignItems: "center", gap: 4, marginTop: 1 }}><div style={{ width: 5, height: 5, borderRadius: "50%", background: loading ? "#FB923C" : "#34D399", boxShadow: `0 0 5px ${loading ? "#FB923C" : "#34D399"}` }} /><span style={{ fontSize: 9, color: "rgba(245,247,252,.28)" }}>{agent.role}</span></div>
            </div>
          </div>
          <button onClick={() => setConvos((p) => ({ ...p, [agent.id]: [] }))} style={{ background: "transparent", border: "1px solid rgba(255,255,255,.05)", borderRadius: 7, padding: "5px 11px", cursor: "pointer", fontSize: 10.5, color: "rgba(245,247,252,.28)" }}>Leeren</button>
        </div>

        {/* Messages */}
        <div style={{ flex: 1, overflowY: "auto", padding: "14px 16px 8px", display: "flex", flexDirection: "column", gap: 10 }}>
          {msgs.length === 0 ? (
            <div style={{ display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", height: "100%", gap: 14, animation: "fadeUp .3s ease" }}>
              <div style={{ width: 60, height: 60, borderRadius: 17, background: `${agent.color}16`, border: `1.5px solid ${agent.color}30`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 27 }}>{agent.emoji}</div>
              <div style={{ textAlign: "center" }}><div style={{ fontSize: 17, fontWeight: 700, marginBottom: 5 }}>{agent.name}</div><div style={{ fontSize: 13, color: "rgba(245,247,252,.5)" }}>{agent.role}</div></div>
              <div style={{ display: "flex", flexWrap: "wrap", gap: 7, justifyContent: "center", maxWidth: 420 }}>
                {[`Was ist die beste Strategie für mein Business?`, `Gib mir 3 konkrete Ideen`, `Wie fange ich an?`].map((s) => (
                  <button key={s} className="chip" onClick={() => send(s)} style={{ padding: "7px 13px", background: `${agent.color}0D`, border: `1px solid ${agent.color}25`, borderRadius: 18, color: "rgba(245,247,252,.55)", cursor: "pointer", fontSize: 11.5, transition: "all .15s" }}>{s}</button>
                ))}
              </div>
            </div>
          ) : (
            msgs.map((msg, i) => (
              <div key={i} className="msg" style={{ display: "flex", justifyContent: msg.role === "user" ? "flex-end" : "flex-start", alignItems: "flex-end", gap: 6 }}>
                {msg.role === "assistant" && <div style={{ width: 24, height: 24, minWidth: 24, borderRadius: 7, background: `${agent.color}18`, border: `1px solid ${agent.color}28`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11, flexShrink: 0 }}>{agent.emoji}</div>}
                <div style={{ maxWidth: "76%", padding: "10px 13px", borderRadius: msg.role === "user" ? "14px 14px 4px 14px" : "14px 14px 14px 4px", background: msg.role === "user" ? `linear-gradient(135deg,${agent.color},${agent.color}CC)` : "rgba(255,255,255,.07)", border: msg.role === "user" ? "none" : "1px solid rgba(255,255,255,.08)", color: "#fff", fontSize: 14, lineHeight: 1.65, whiteSpace: "pre-wrap", wordBreak: "break-word" }}>{msg.content}</div>
              </div>
            ))
          )}
          {loading && (
            <div className="msg" style={{ display: "flex", alignItems: "flex-end", gap: 6 }}>
              <div style={{ width: 24, height: 24, minWidth: 24, borderRadius: 7, background: `${agent.color}18`, border: `1px solid ${agent.color}28`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11 }}>{agent.emoji}</div>
              <div style={{ padding: "11px 14px", background: "rgba(255,255,255,.07)", border: "1px solid rgba(255,255,255,.08)", borderRadius: "13px 13px 13px 4px", display: "flex", gap: 4 }}>
                {[0, 1, 2].map((i) => <div key={i} style={{ width: 5, height: 5, borderRadius: "50%", background: agent.color, animation: `dot 1.2s ease ${i * .17}s infinite` }} />)}
              </div>
            </div>
          )}
          <div ref={endRef} />
        </div>

        {/* Input */}
        <div style={{ padding: "10px 16px 14px", borderTop: "1px solid rgba(255,255,255,.08)", background: "rgba(18,20,28,.9)", backdropFilter: "blur(24px)", flexShrink: 0 }}>
          <div style={{ display: "flex", gap: 7, alignItems: "flex-end", background: "rgba(255,255,255,.05)", border: `1.5px solid ${input ? agent.color + "50" : "rgba(255,255,255,.08)"}`, borderRadius: 13, padding: "7px 7px 7px 13px", transition: "border-color .18s" }}>
            <textarea ref={taRef} value={input} onChange={(e) => setInput(e.target.value)} onKeyDown={onKey} placeholder={`Nachricht an ${agent.name}...`} rows={1} style={{ flex: 1, background: "transparent", border: "none", outline: "none", color: "#F5F7FC", fontSize: 14, lineHeight: 1.5, resize: "none", maxHeight: 100, padding: "2px 0" }} onInput={(e) => { e.target.style.height = "auto"; e.target.style.height = Math.min(e.target.scrollHeight, 100) + "px"; }} />
            <button className="sendbtn" onClick={() => send()} disabled={!input.trim() || loading} style={{ width: 30, height: 30, borderRadius: 8, border: "none", background: input.trim() && !loading ? `linear-gradient(135deg,${agent.color},${agent.color}CC)` : "rgba(255,255,255,.08)", cursor: input.trim() && !loading ? "pointer" : "default", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 15, color: "#fff", flexShrink: 0, transition: "all .15s" }}>↑</button>
          </div>
          <div style={{ fontSize: 9, color: "rgba(245,247,252,.2)", marginTop: 5, textAlign: "center" }}>Enter senden · Shift+Enter neue Zeile</div>
        </div>
      </div>
    </div>
  );
}
