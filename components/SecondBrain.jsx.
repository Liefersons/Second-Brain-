                      <div style={{fontSize:13,color:C.t1,lineHeight:1.6,whiteSpace:"pre-wrap"}}>{checkIn.msg}</div>
                      <div style={{display:"flex",gap:7,marginTop:11}}>
                        <button className="hov" onClick={()=>{setCheckIn(null);setActiveId("innovator");setView("chat");setTimeout(()=>sendChat("Lass uns weiter an dieser Idee arbeiten: "+checkIn.idea.text),200);}} style={{padding:"7px 15px",background:`linear-gradient(135deg,${C.blue},${C.violet})`,border:"none",borderRadius:9,color:"#fff",cursor:"pointer",fontSize:11.5,fontWeight:600}}>Weiterentwickeln →</button>
                        <button className="hov" onClick={()=>setCheckIn(null)} style={{padding:"7px 13px",background:"transparent",border:`1px solid ${C.soft}`,borderRadius:9,color:C.t3,cursor:"pointer",fontSize:11.5}}>Später</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            )}

            <div style={{textAlign:"center",marginBottom:10,animation:"fu .4s ease"}}>
              <h1 style={{fontSize:21,fontWeight:800,margin:0,letterSpacing:"-.3px",background:`linear-gradient(135deg,${C.t1},${C.t2})`,WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>{profile.name?`Willkommen, ${profile.name.split(" ")[0]}`:"Second Brain"}</h1>
              <div style={{fontSize:10,color:C.t3,marginTop:4,display:"flex",alignItems:"center",gap:6,justifyContent:"center",fontFamily:MONO,letterSpacing:".05em"}}><div style={{width:5,height:5,borderRadius:"50%",background:briefLoad||loading||rState?C.orange:C.green,boxShadow:`0 0 6px ${briefLoad||loading||rState?C.orange:C.green}`}}/><span style={{animation:"pulse 2s ease-in-out infinite"}}>{status.toUpperCase()}</span></div>
            </div>

            <div style={{width:"100%",maxWidth:480,marginBottom:14,animation:"fu .45s ease",borderRadius:20,overflow:"hidden",border:`1px solid ${C.sep}`,background:"rgba(6,7,12,.7)",padding:6,position:"relative"}}>
              <div style={{position:"absolute",top:0,left:0,right:0,height:"1px",background:`linear-gradient(90deg,transparent,${faceAccent}50,transparent)`,animation:"borderFlow 4s ease infinite"}}/>
              <BrainViz agents={agents} activeId={activeId} faceState={faceState}/>
            </div>

            <form onSubmit={handleSearch} style={{width:"100%",maxWidth:480,marginBottom:14,animation:"fu .5s ease"}}>
              <div style={{display:"flex",alignItems:"center",gap:11,background:C.s1,backdropFilter:"blur(40px) saturate(180%)",WebkitBackdropFilter:"blur(40px) saturate(180%)",border:`1.5px solid ${searchVal?faceAccent+"60":C.sep}`,borderRadius:15,padding:"14px 16px",boxShadow:searchVal?`0 0 0 4px ${faceAccent}12,0 12px 40px rgba(0,0,0,.5)`:"0 6px 28px rgba(0,0,0,.35)",transition:"all .25s cubic-bezier(.2,.8,.2,1)"}}>
                {rState?(
                  <div style={{display:"flex",alignItems:"center",gap:11,flex:1}}>{rState.phase==="thinking"?<><div style={{display:"flex",gap:3}}>{[0,1,2].map(i=><div key={i} style={{width:5,height:5,borderRadius:"50%",background:C.blue,animation:`pulse 1s ease ${i*.15}s infinite`}}/>)}</div><span style={{fontSize:13.5,color:C.t2,fontFamily:MONO}}>Neural routing…</span></>:<><div style={{width:28,height:28,borderRadius:8,background:`${rState.accent}22`,border:`1px solid ${rState.accent}40`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:14,color:rState.accent}}>{rState.emoji}</div><div><div style={{fontSize:9,color:C.t3,fontFamily:MONO,letterSpacing:".05em"}}>ROUTING →</div><div style={{fontSize:14,fontWeight:600}}>{rState.name}</div></div></>}</div>
                ):(<><span style={{color:faceAccent,fontSize:16,flexShrink:0}}>⌕</span><input ref={inputRef} value={searchVal} onChange={e=>setSearchVal(e.target.value)} placeholder="Frag dein Brain – alles, jederzeit…" style={{flex:1,background:"transparent",border:"none",outline:"none",fontSize:14.5,color:C.t1,lineHeight:1.4}}/>{searchVal&&<div style={{fontSize:9.5,color:C.t3,background:C.t4,padding:"3px 8px",borderRadius:6,flexShrink:0,fontFamily:MONO}}>↵ ENTER</div>}</>)}
              </div>
            </form>

            <div style={{width:"100%",maxWidth:480,marginBottom:14,animation:"fu .55s ease"}}>
              <div style={{background:`linear-gradient(135deg,${C.green}0A,transparent)`,border:`1px solid ${C.green}1E`,borderRadius:13,padding:"13px 15px",position:"relative",overflow:"hidden"}}>
                <div style={{position:"absolute",top:0,left:0,right:0,height:"1.5px",background:`linear-gradient(90deg,${C.green}80,transparent)`}}/>
                <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:8}}><div style={{display:"flex",alignItems:"center",gap:7}}><span style={{fontSize:12}}>📡</span><span style={{fontSize:9.5,fontWeight:700,color:C.green,letterSpacing:".1em",fontFamily:MONO}}>LIVE MARKT-BRIEFING</span></div><div style={{display:"flex",gap:6,alignItems:"center"}}>{briefing&&<span style={{fontSize:8.5,color:C.t3,fontFamily:MONO}}>{briefing.time.toLocaleTimeString("de-DE",{hour:"2-digit",minute:"2-digit"})}</span>}<button className="hov" onClick={()=>{setBriefing(null);setBriefLoad(false);}} style={{fontSize:10,color:C.t3,background:"transparent",border:"none",cursor:"pointer"}}>↺</button></div></div>
                {briefLoad?<div style={{display:"flex",alignItems:"center",gap:8,padding:"2px 0"}}><div style={{width:12,height:12,border:`1.5px solid ${C.green}`,borderTopColor:"transparent",borderRadius:"50%",animation:"spin .8s linear infinite"}}/><span style={{fontSize:11.5,color:C.t3}}>Scanne globale Märkte…</span></div>:briefing?<div style={{fontSize:12,color:C.t2,lineHeight:1.75,whiteSpace:"pre-wrap"}}>{briefing.text}</div>:<div style={{fontSize:11.5,color:C.t3}}>Lädt…</div>}
              </div>
            </div>

            <div style={{width:"100%",maxWidth:480,animation:"fu .6s ease"}}>
              <div style={{fontSize:9,fontWeight:700,color:C.t3,letterSpacing:".15em",marginBottom:11,fontFamily:MONO}}>ALLE AGENTEN</div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(150px,1fr))",gap:9}}>
                {agents.map((ag,i)=>{const n=(convos[ag.id]||[]).filter(m=>m.role==="user").length;return(
                  <button key={ag.id} className="card" onClick={()=>{setActiveId(ag.id);setView("chat");}} style={{background:"rgba(255,255,255,.035)",border:`1px solid ${C.sep}`,borderRadius:14,padding:"14px 12px",cursor:"pointer",textAlign:"left",animation:`fu ${.4+i*.04}s ease`,position:"relative",overflow:"hidden"}}>
                    <div style={{position:"absolute",top:0,left:0,right:0,height:"2px",background:`linear-gradient(90deg,${ag.accent}70,transparent)`}}/>
                    <div style={{width:36,height:36,borderRadius:10,background:`${ag.accent}18`,border:`1px solid ${ag.accent}30`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:17,marginBottom:9,color:ag.accent}}>{ag.emoji}</div>
                    <div style={{fontSize:12.5,fontWeight:600,color:C.t1,marginBottom:2}}>{ag.name}</div>
                    <div style={{fontSize:10,color:C.t2,lineHeight:1.4}}>{ag.role}</div>
                    {n>0&&<div style={{position:"absolute",top:11,right:11,background:`${ag.accent}1E`,color:ag.accent,borderRadius:7,fontSize:8.5,fontWeight:700,padding:"2px 6px"}}>{n}</div>}
                  </button>
                );})}
              </div>
            </div>
          </div>
        )}

        {view==="chat"&&activeAgent&&(
          <>
            <div style={{padding:"10px 16px",borderBottom:`1px solid ${C.sep}`,background:C.s1,backdropFilter:"blur(40px) saturate(180%)",WebkitBackdropFilter:"blur(40px) saturate(180%)",display:"flex",alignItems:"center",justifyContent:"space-between",flexShrink:0}}>
              <div style={{display:"flex",alignItems:"center",gap:10}}>
                <button className="hov" onClick={()=>setView("dash")} style={{background:C.t4,border:"none",borderRadius:8,padding:"5px 10px",cursor:"pointer",fontSize:11,color:C.t2}}>← Brain</button>
                <div style={{width:1,height:14,background:C.sep}}/>
                <div style={{lineHeight:0,flexShrink:0}}><RobotFace state={faceState} accent={ac} width={50} height={62}/></div>
                <div><div style={{fontSize:13.5,fontWeight:600,color:C.t1}}>{activeAgent.name}</div><div style={{display:"flex",alignItems:"center",gap:4,marginTop:1}}><div style={{width:4,height:4,borderRadius:"50%",background:loading?C.orange:C.green,boxShadow:`0 0 5px ${loading?C.orange:C.green}`}}/><span style={{fontSize:8.5,color:C.t3,fontFamily:MONO}}>{loading?status.toUpperCase():activeAgent.role}</span></div></div>
              </div>
              <button className="hov" onClick={()=>setConvos(p=>({...p,[activeId]:[]}))} style={{background:"transparent",border:`1px solid ${C.soft}`,borderRadius:8,padding:"5px 11px",cursor:"pointer",fontSize:10.5,color:C.t3}}>Leeren</button>
            </div>

            <div style={{flex:1,overflowY:"auto",padding:"14px 16px 6px",display:"flex",flexDirection:"column",gap:9}}>
              {msgs.length===0?(
                <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",height:"100%",gap:12,animation:"si .3s ease"}}>
                  <div style={{animation:"float 3.5s ease-in-out infinite",filter:`drop-shadow(0 8px 32px ${ac}30)`}}><RobotFace state="idle" accent={ac} width={140} height={174}/></div>
                  <div style={{textAlign:"center"}}><div style={{fontSize:16,fontWeight:700,marginBottom:3}}>{activeAgent.name}</div><div style={{fontSize:12.5,color:C.t2}}>{activeAgent.role}</div></div>
                </div>
              ):(msgs.map((msg,i)=>(
                <div key={i} style={{display:"flex",justifyContent:msg.role==="user"?"flex-end":"flex-start",alignItems:"flex-end",gap:6,animation:"msgIn .22s ease"}}>
                  {msg.role==="assistant"&&<div style={{lineHeight:0,flexShrink:0,marginBottom:2}}><RobotFace state="idle" accent={ac} width={26} height={32}/></div>}
                  <div style={{maxWidth:"77%",padding:"10px 13px",borderRadius:msg.role==="user"?"15px 15px 4px 15px":"15px 15px 15px 4px",background:msg.role==="user"?`linear-gradient(135deg,${ac},${ac}CC)`:"rgba(255,255,255,.06)",border:msg.role==="user"?"none":`1px solid ${C.sep}`,color:msg.role==="user"?"#fff":C.t1,fontSize:14,lineHeight:1.65,whiteSpace:"pre-wrap",wordBreak:"break-word",boxShadow:msg.role==="user"?`0 4px 16px ${ac}30`:"none"}}>{isYT(msg.content)&&msg.role==="user"&&<div style={{fontSize:9,opacity:.6,marginBottom:2}}>🎥 YouTube</div>}{msg.content}</div>
                </div>
              )))}
              {loading&&<div style={{display:"flex",alignItems:"flex-end",gap:6,animation:"msgIn .2s ease"}}><div style={{lineHeight:0,flexShrink:0}}><RobotFace state="speaking" accent={ac} width={26} height={32}/></div><div style={{padding:"11px 14px",background:"rgba(255,255,255,.06)",border:`1px solid ${C.sep}`,borderRadius:"15px 15px 15px 4px",display:"flex",gap:4}}>{[0,1,2].map(i=><div key={i} style={{width:5,height:5,borderRadius:"50%",background:ac,animation:`pulse 1.2s ease ${i*.17}s infinite`}}/>)}</div></div>}
              <div ref={endRef}/>
            </div>

            <div style={{padding:"10px 16px 14px",borderTop:`1px solid ${C.sep}`,background:C.s1,backdropFilter:"blur(40px) saturate(180%)",WebkitBackdropFilter:"blur(40px) saturate(180%)",flexShrink:0}}>
              {isYT(chatVal)&&<div style={{marginBottom:5,padding:"4px 10px",background:`${C.red}14`,border:`1px solid ${C.red}28`,borderRadius:8,fontSize:10,color:C.red}}>🎥 YouTube erkannt – wird analysiert</div>}
              <div style={{display:"flex",gap:7,alignItems:"flex-end",background:"rgba(255,255,255,.05)",border:`1.5px solid ${chatVal?ac+"50":C.sep}`,borderRadius:14,padding:"7px 7px 7px 13px",transition:"border-color .18s",boxShadow:chatVal?`0 0 0 3px ${ac}12`:"none"}}>
                <textarea ref={chatRef} value={chatVal} onChange={e=>setChatVal(e.target.value)} onKeyDown={onKey} placeholder={`Nachricht an ${activeAgent.name}…`} rows={1} style={{flex:1,background:"transparent",border:"none",outline:"none",color:C.t1,fontSize:14,lineHeight:1.5,resize:"none",maxHeight:100,padding:"2px 0"}} onInput={e=>{e.target.style.height="auto";e.target.style.height=Math.min(e.target.scrollHeight,100)+"px";}}/>
                <button className="sb" onClick={()=>sendChat()} disabled={!chatVal.trim()||loading} style={{width:30,height:30,borderRadius:9,border:"none",background:chatVal.trim()&&!loading?`linear-gradient(135deg,${ac},${ac}CC)`:"rgba(255,255,255,.08)",cursor:chatVal.trim()&&!loading?"pointer":"default",display:"flex",alignItems:"center",justifyContent:"center",fontSize:15,color:"#fff",flexShrink:0,boxShadow:chatVal.trim()&&!loading?`0 2px 12px ${ac}40`:"none"}}>↑</button>
              </div>
              <div style={{fontSize:8.5,color:C.t3,marginTop:4,textAlign:"center",fontFamily:MONO,letterSpacing:".03em"}}>ENTER SENDEN · ICH LERNE DICH BEI JEDEM GESPRÄCH BESSER KENNEN</div>
            </div>
          </>
        )}
      </div>

      {/* ══ ONBOARDING ══ */}
      {onboard&&(
        <div style={{position:"fixed",inset:0,background:"rgba(6,7,10,.96)",backdropFilter:"blur(20px)",WebkitBackdropFilter:"blur(20px)",zIndex:250,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24}}>
          {/* progress */}
          <div style={{position:"absolute",top:30,left:0,right:0,display:"flex",justifyContent:"center",gap:6}}>
            {ONBOARD_Q.map((_,i)=><div key={i} style={{width:i===obStep?22:8,height:4,borderRadius:2,background:i<=obStep?C.blue:C.t4,transition:"all .3s ease"}}/>)}
          </div>
          <div key={obStep} style={{width:"100%",maxWidth:440,animation:"qIn .4s cubic-bezier(.2,.8,.2,1)",display:"flex",flexDirection:"column",alignItems:"center",gap:20}}>
            <div style={{animation:"float 4s ease-in-out infinite",filter:`drop-shadow(0 8px 32px ${C.blue}35)`}}><RobotFace state="speaking" accent={C.blue} width={120} height={148}/></div>
            <div style={{textAlign:"center"}}>
              <div style={{fontSize:9,fontWeight:700,color:C.blue,letterSpacing:".15em",marginBottom:10,fontFamily:MONO}}>KENNENLERNEN · {obStep+1}/{ONBOARD_Q.length}</div>
              <div style={{fontSize:17,fontWeight:600,color:C.t1,lineHeight:1.55,whiteSpace:"pre-wrap"}}>{ONBOARD_Q[obStep].q.replace("{name}",obData.name?" "+obData.name.split(" ")[0]:"")}</div>
            </div>
            {ONBOARD_Q[obStep].chips.length>0&&(
              <div style={{display:"flex",flexWrap:"wrap",gap:7,justifyContent:"center"}}>
                {ONBOARD_Q[obStep].chips.map(c=>(
                  <button key={c} className="obchip" onClick={()=>obSubmit(c)} style={{padding:"8px 14px",background:C.t4,border:`1px solid ${C.sep}`,borderRadius:20,color:C.t2,cursor:"pointer",fontSize:12.5}}>{c}</button>
                ))}
              </div>
            )}
            <div style={{width:"100%",display:"flex",gap:8,alignItems:"center",background:"rgba(255,255,255,.05)",border:`1.5px solid ${obVal?C.blue+"50":C.sep}`,borderRadius:14,padding:"8px 8px 8px 15px",transition:"border-color .18s"}}>
              <input ref={obRef} value={obVal} onChange={e=>setObVal(e.target.value)} onKeyDown={e=>{if(e.key==="Enter"){e.preventDefault();obSubmit();}}} placeholder={ONBOARD_Q[obStep].ph} style={{flex:1,background:"transparent",border:"none",outline:"none",color:C.t1,fontSize:14.5,lineHeight:1.4}}/>
              <button className="sb" onClick={()=>obSubmit()} disabled={!obVal.trim()} style={{width:34,height:34,borderRadius:10,border:"none",background:obVal.trim()?`linear-gradient(135deg,${C.blue},${C.violet})`:"rgba(255,255,255,.08)",cursor:obVal.trim()?"pointer":"default",display:"flex",alignItems:"center",justifyContent:"center",fontSize:16,color:"#fff",flexShrink:0}}>→</button>
            </div>
            <button className="hov" onClick={async()=>{const np={...profile,...obData};setProfile(np);await saveProfile(np);setOnboard(false);setObStep(0);}} style={{background:"transparent",border:"none",color:C.t3,cursor:"pointer",fontSize:11,fontFamily:MONO,letterSpacing:".05em"}}>ÜBERSPRINGEN</button>
          </div>
        </div>
      )}

      {/* ══ PROVIDER MODAL ══ */}
      {showProvider&&(
        <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.8)",backdropFilter:"blur(20px)",WebkitBackdropFilter:"blur(20px)",zIndex:200,display:"flex",alignItems:"center",justifyContent:"center",padding:20}} onClick={e=>{if(e.target===e.currentTarget)setShowProvider(false);}}>
          <div style={{background:C.s1,backdropFilter:"blur(40px)",WebkitBackdropFilter:"blur(40px)",border:`1px solid ${C.sep}`,borderRadius:22,padding:"24px",width:"100%",maxWidth:400,boxShadow:"0 32px 90px rgba(0,0,0,.7)",animation:"si .25s cubic-bezier(.2,.8,.2,1)",position:"relative",overflow:"hidden"}}>
            <div style={{position:"absolute",top:0,left:0,right:0,height:"2px",background:`linear-gradient(90deg,${pv.color},transparent)`}}/>
            <div style={{marginBottom:18}}><div style={{fontSize:18,fontWeight:700,marginBottom:5}}>KI-Modell wählen</div><div style={{fontSize:12,color:C.t2,lineHeight:1.6}}>Wähle, welche KI deinen Agenten antreibt. Umstellung auf Gemini/ChatGPT funktioniert beim Eigenbetrieb mit deinem API-Schlüssel.</div></div>
            {Object.entries(PROVIDERS).map(([id,p])=>(
              <button key={id} className="hov" onClick={()=>{setProvider(id);setShowProvider(false);}} style={{width:"100%",marginBottom:8,padding:"13px 14px",background:provider===id?`${p.color}14`:C.t4,border:`1.5px solid ${provider===id?p.color+"50":C.sep}`,borderRadius:12,cursor:"pointer",display:"flex",alignItems:"center",gap:11,textAlign:"left"}}>
                <div style={{width:10,height:10,borderRadius:"50%",background:p.color,boxShadow:`0 0 8px ${p.color}`,flexShrink:0}}/>
                <div style={{flex:1}}><div style={{fontSize:13.5,fontWeight:600,color:C.t1,display:"flex",alignItems:"center",gap:7}}>{p.name}{p.live&&<span style={{fontSize:8,fontWeight:700,color:C.green,background:`${C.green}1E`,padding:"2px 6px",borderRadius:5,fontFamily:MONO}}>LÄUFT HIER</span>}{!p.live&&<span style={{fontSize:8,fontWeight:700,color:C.t3,background:C.t4,padding:"2px 6px",borderRadius:5,fontFamily:MONO}}>EIGENER KEY</span>}</div><div style={{fontSize:10.5,color:C.t3,marginTop:2}}>{p.sub}</div></div>
                {provider===id&&<span style={{color:p.color,fontSize:16}}>✓</span>}
              </button>
            ))}
            <div style={{marginTop:14,padding:"11px 13px",background:`${C.blue}0C`,border:`1px solid ${C.blue}20`,borderRadius:10,fontSize:11,color:C.t2,lineHeight:1.6}}>
              💡 <strong style={{color:C.t1}}>Tipp:</strong> Gemini hat ein kostenloses Tageskontingent. Beim Eigenbetrieb (Vercel/lokal) trägst du deinen Schlüssel ein und sparst Kosten.
            </div>
          </div>
        </div>
      )}

      {/* ══ PROFILE MODAL ══ */}
      {showProf&&(
        <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.8)",backdropFilter:"blur(20px)",WebkitBackdropFilter:"blur(20px)",zIndex:200,display:"flex",alignItems:"center",justifyContent:"center",padding:20}} onClick={e=>{if(e.target===e.currentTarget)setShowProf(false);}}>
          <div style={{background:C.s1,backdropFilter:"blur(40px) saturate(180%)",WebkitBackdropFilter:"blur(40px) saturate(180%)",border:`1px solid ${C.sep}`,borderRadius:22,padding:"26px",width:"100%",maxWidth:390,maxHeight:"85vh",overflowY:"auto",boxShadow:"0 32px 90px rgba(0,0,0,.7)",animation:"si .25s cubic-bezier(.2,.8,.2,1)",position:"relative"}}>
            <div style={{position:"absolute",top:0,left:0,right:0,height:"2px",background:`linear-gradient(90deg,${C.violet},${C.cyan},transparent)`}}/>
            <div style={{marginBottom:20}}><div style={{fontSize:19,fontWeight:700,marginBottom:5}}>Dein Profil</div><div style={{fontSize:12.5,color:C.t2,lineHeight:1.6}}>Alle Agenten nutzen diese Infos. Ich ergänze sie automatisch, wenn ich dich besser kennenlerne.</div></div>
            {[{k:"name",l:"Name"},{k:"job",l:"Beruf / Tätigkeit"},{k:"goals",l:"Wichtigste Ziele"},{k:"focus",l:"Hauptfokus"},{k:"style",l:"Antwortstil"},{k:"context",l:"Kontext"}].map(f=>(
              <div key={f.k} style={{marginBottom:12}}><label style={{display:"block",fontSize:9,fontWeight:700,color:C.t3,marginBottom:5,letterSpacing:".1em",fontFamily:MONO}}>{f.l.toUpperCase()}</label><input value={profDraft[f.k]||""} onChange={e=>setProfDraft(p=>({...p,[f.k]:e.target.value}))} style={{width:"100%",padding:"10px 13px",background:C.t4,border:`1px solid ${C.sep}`,borderRadius:10,color:C.t1,fontSize:13.5,outline:"none",transition:"border-color .15s"}} onFocus={e=>e.target.style.borderColor=C.blue+"60"} onBlur={e=>e.target.style.borderColor=C.sep}/></div>
            ))}
            {profile.learned&&(
              <div style={{marginBottom:12}}><label style={{display:"block",fontSize:9,fontWeight:700,color:C.green,marginBottom:5,letterSpacing:".1em",fontFamily:MONO}}>🧠 AUTOMATISCH GELERNT</label><div style={{padding:"10px 13px",background:`${C.green}0A`,border:`1px solid ${C.green}20`,borderRadius:10,color:C.t2,fontSize:11.5,lineHeight:1.5}}>{profile.learned}</div></div>
            )}
            <div style={{display:"flex",gap:8,marginTop:20}}>
              <button className="hov" onClick={()=>setShowProf(false)} style={{flex:1,padding:"11px",background:"transparent",border:`1px solid ${C.sep}`,borderRadius:11,color:C.t2,cursor:"pointer",fontSize:12.5}}>Abbrechen</button>
              <button className="hov" onClick={async()=>{setProfile(profDraft);await saveProfile(profDraft);setShowProf(false);}} style={{flex:2,padding:"11px",background:`linear-gradient(135deg,${C.blue},${C.violet})`,border:"none",borderRadius:11,color:"#fff",cursor:"pointer",fontSize:12.5,fontWeight:600}}>Speichern</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
