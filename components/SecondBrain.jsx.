function extractLearned(text){const m=text.match(/\[MERKEN:\s*([^\]]+)\]/i);return m?m[1].trim():null;}
function stripLearned(text){return text.replace(/\[MERKEN:[^\]]*\]/gi,"").trim();}

// Routing: keep simple keyword fallback if API fails, so chat ALWAYS proceeds.
function keywordRoute(q,agents){
  const t=q.toLowerCase();let best=agents[0],score=0;
  agents.forEach(a=>{const s=(a.kw||"").split(" ").filter(k=>k&&t.includes(k)).length;if(s>score){score=s;best=a;}});
  return {primary:best.id,isNew:false,newAgent:null};
}
async function routeQuery(q,agents){
  const list=agents.map(a=>`"${a.id}": ${a.name} [${a.kw}]`).join(' | ');
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,messages:[{role:"user",content:`Ordne diese Anfrage dem besten Agenten zu. Antworte NUR mit JSON.\nAgenten: ${list}\nFormat: {"primary":"agent_id"}\nAnfrage: "${q}"`}]})});
    let d;try{d=await r.json();}catch{return keywordRoute(q,agents);}
    if(!d||d.error)return keywordRoute(q,agents);
    let txt="";
    if(Array.isArray(d.content))txt=d.content.filter(b=>b&&b.type==="text").map(b=>b.text).join("");
    else if(typeof d.content==="string")txt=d.content;
    txt=(txt||"").replace(/```json|```/g,"").trim();
    const match=txt.match(/\{[^}]*\}/);
    if(match){try{const p=JSON.parse(match[0]);if(p&&p.primary&&agents.some(a=>a.id===p.primary))return p;}catch{}}
    return keywordRoute(q,agents);
  }catch{return keywordRoute(q,agents);}
}
// Built-in fallback so the user ALWAYS gets a useful answer, even if the API proxy fails.
function fallbackReply(agentId,q){
  return "⚠️ Verbindungsfehler – bitte nochmal senden.";
}
async function callAPI(sys,messages,agentId){
  const clean=messages.filter(m=>m.role==="user"||m.role==="assistant");
  // Kein separater system-Parameter – in messages einbetten
  const apiMsgs=sys&&sys.trim()
    ?[{role:"user",content:`Anweisung für dieses Gespräch:\n${sys.substring(0,700)}`},{role:"assistant",content:"Verstanden. Ich folge diesen Anweisungen."},...clean]
    :clean;
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,messages:apiMsgs})
    });
    const d=await r.json();
    const txt=(d.content||[]).filter(b=>b?.type==="text"&&b.text).map(b=>b.text).join("\n").trim();
    if(txt)return txt;
    if(d.error)return `⚠️ ${d.error.message||"Fehler"} – bitte nochmal senden.`;
    return "⚠️ Keine Antwort – bitte nochmal senden.";
  }catch{
    return "⚠️ Verbindungsfehler – bitte nochmal senden.";
  }
}

