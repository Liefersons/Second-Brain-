  useEffect(()=>{stRef.current=state;},[state]);useEffect(()=>{acRef.current=accent;},[accent]);
  useEffect(()=>{const cv=cvRef.current;if(!cv)return;const ctx=cv.getContext("2d");let last=0,raf;const loop=(now)=>{const dt=Math.min(now-last,50);last=now;const a=animRef.current;a.t+=dt*.001;a.glow=.5+.5*Math.sin(a.t*2.2);a.blinkAcc+=dt;if(!a.blink&&a.blinkAcc>a.nextBlink){a.blink=true;a.blinkAcc=0;a.nextBlink=2400+Math.random()*2200;setTimeout(()=>{animRef.current.blink=false;},140);}const s=stRef.current;if(s==="thinking"||s==="routing"){a.px=Math.sin(a.t*2.8)*7;a.py=Math.sin(a.t*1.4)*2.5;}else{a.px+=(Math.sin(a.t*.4)*3-a.px)*.015;a.py+=(Math.cos(a.t*.3)*2-a.py)*.015;}drawFace(ctx,cv.width,cv.height,s,acRef.current,a);raf=requestAnimationFrame(loop);};raf=requestAnimationFrame(loop);return()=>cancelAnimationFrame(raf);},[]);
  return <canvas ref={cvRef} width={width} height={height} style={{display:"block"}}/>;
}

